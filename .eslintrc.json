{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "react/no-unescaped-entities": "off"
  },
  "ignorePatterns": [
    ".next/**",
    "out/**",
    "build/**",
    "node_modules/**",
    "chrome-extension/**",
    "chrome-extension-meta/**",
    "chrome-extension-veo/**",
    "dist-test/**",
    "local_worker/**",
    "workers/**",
    "remotion/**"
  ]
}
