{
    "manifest_version": 3,
    "name": "SeenYT - YouTube AI Tools",
    "version": "1.0.0",
    "description": "Công cụ phân tích YouTube thông minh. Xem tags, views, và nhiều hơn nữa!",
    "action": {
        "default_popup": "src/popup/index.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/watch*",
                "*://*.youtube.com/channel/*",
                "*://*.youtube.com/c/*",
                "*://*.youtube.com/@*",
                "*://studio.youtube.com/*"
            ],
            "js": [
                "assets/content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "*://*.youtube.com/*",
        "*://studio.youtube.com/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "icons/*"
            ],
            "matches": [
                "*://*.youtube.com/*"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}