{
    "manifest_version": 3,
    "name": "SeenYT - VidIQ Killer 🔥",
    "version": "2.0.0",
    "description": "Đánh bại VidIQ! SEO Score, AI Suggestions, Keyword Insights & nhiều hơn nữa!",
    "action": {
        "default_popup": "src/popup/index.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/watch*",
                "*://*.youtube.com/channel/*",
                "*://*.youtube.com/c/*",
                "*://*.youtube.com/@*",
                "*://studio.youtube.com/*",
                "*://*.seenyt.net/*",
                "*://localhost/*"
            ],
            "js": [
                "assets/content.js"
            ],
            "run_at": "document_end"
        }
    ],
    "permissions": [
        "storage",
        "activeTab",
        "clipboardWrite"
    ],
    "host_permissions": [
        "*://*.youtube.com/*",
        "*://studio.youtube.com/*",
        "*://*.seenyt.net/*",
        "https://seenyt.net/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "assets/*",
                "assets/inpage.js",
                "icons/*"
            ],
            "matches": [
                "*://*.youtube.com/*"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}