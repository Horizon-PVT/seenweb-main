generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  image              String?
  passwordHash       String?
  role               String    @default("FREE")

  // QUOTA FIELDS
  dailyUsage         Int       @default(0)
  maxDailyUsage      Int       @default(3) // Updated from 2 to 3

  // ✅ NEW: dùng để reset dailyUsage theo ngày (không cần cron)
  lastUsageDate      DateTime? // New field for daily reset logic

  // TTS QUOTA TRACKING
  ttsUsageChars      Int       @default(0)
  ttsLastReset       String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  membershipExpiry   DateTime?

  // AFFILIATE FIELDS (self-relation referrer / referredUsers)
  referrerId         String?
  referrer           User?     @relation("ReferralRelation", fields: [referrerId], references: [id])
  referredUsers      User[]    @relation("ReferralRelation")
  affiliateCode      String?   @unique
  isAffiliate        Boolean   @default(false)
  totalCommission    Decimal   @default(0)

  // Relations
  paymentRequests     PaymentRequest[]
  commissions         Commission[]    @relation("UserCommissions")
  referredCommissions Commission[]   @relation("CommissionReferredUser")
  payoutRequests      PayoutRequest[] @relation("UserPayouts")
  
  // Analytics
  attribution         UserAttribution?
  events              Event[]

  @@map("users")
}

model PaymentRequest {
  id           String    @id @default(cuid())
  orderCode    String    @unique
  userId       String?
  email        String
  role         String
  amount       Int
  txn          String?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  paidAt       DateTime?

  paymentInfo  String?

  approvedAt   DateTime?
  approvedBy   String?
  note         String?

  user         User?     @relation(fields: [userId], references: [id])

  @@map("payment_requests")
}

model Commission {
  id               String   @id @default(cuid())
  referrerId       String
  referredUserId   String
  paymentRequestId String?
  type             String
  amount           Decimal
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  approvedAt       DateTime?

  referrer         User     @relation("UserCommissions", fields: [referrerId], references: [id])
  referredUser     User     @relation("CommissionReferredUser", fields: [referredUserId], references: [id])

  @@map("commissions")
}

model PayoutRequest {
  id              String   @id @default(cuid())
  affiliateId     String
  amountRequested Decimal
  amountApproved  Decimal?
  bankInfo        Json
  status          String   @default("PENDING")
  requestedAt     DateTime @default(now())
  processedAt     DateTime?
  note            String?

  affiliate       User     @relation("UserPayouts", fields: [affiliateId], references: [id])

  @@map("payout_requests")
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  createdAt DateTime   @default(now())
  posts     BlogPost[]
  
  @@map("blog_categories")
}

model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  coverImage  String?
  summary     String?
  content     String        @db.Text
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  status      String        @default("DRAFT")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  publishedAt DateTime?
  
  @@map("blog_posts")
}

model Ebook {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  coverImageUrl   String?
  pdfUrl          String
  description     String?  @db.Text
  status          String   @default("DRAFT")
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ebooks")
}

model VideoTip {
  id           String   @id @default(cuid())
  title        String
  youtubeUrl   String
  youtubeId    String
  thumbnailUrl String?
  description  String?  @db.Text
  tags         String?
  status       String   @default("DRAFT")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("video_tips")
}

model Promotion {
  id             String    @id @default(cuid())
  code           String    @unique
  type           String    // PERCENT or FIXED
  value          Decimal
  promotionType  String    @default("CODE") // PROGRAM or CODE
  startDate      DateTime?
  endDate        DateTime?
  minOrder       Decimal?
  usageLimit     Int?      // Max usage count (null = unlimited)
  usageCount     Int       @default(0) // Current usage count
  status         String    @default("ACTIVE")
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  @@map("promotions")
}

model UserAttribution {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  anonId          String?

  // First Touch
  firstUtmSource   String?
  firstUtmMedium   String?
  firstUtmCampaign String?
  firstUtmTerm     String?
  firstUtmContent  String?
  firstGclid       String?
  firstReferrer    String?
  firstLandingPath String?
  firstSeenAt      DateTime?

  // Last Touch
  lastUtmSource    String?
  lastUtmMedium    String?
  lastUtmCampaign  String?
  lastUtmTerm      String?
  lastUtmContent   String?
  lastGclid        String?
  lastReferrer     String?
  lastLandingPath  String?
  lastSeenAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_attributions")
}

model Event {
  id          String   @id @default(cuid())
  name        String
  userId      String?
  anonId      String?
  path        String?
  properties  Json?
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([name, createdAt])
  @@index([userId])
  @@index([anonId])
  @@map("events")
}
