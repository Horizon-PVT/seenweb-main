generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  image              String?
  passwordHash       String?
  role               String    @default("FREE")

  // QUOTA FIELDS
  dailyUsage         Int       @default(0)
  maxDailyUsage      Int       @default(3) // Updated from 2 to 3

  // ✅ NEW: dùng để reset dailyUsage theo ngày (không cần cron)
  lastUsageDate      DateTime? // New field for daily reset logic

  // TTS QUOTA TRACKING
  ttsUsageChars      Int       @default(0)
  ttsLastReset       String?

  // AI DUBBING CREDITS
  dubbingCredits     Int       @default(0) // 1 credit = 1 video minute (or similar)

  // VIETNAMESE TTS ADD-ON (59k upsell)
  hasVietnameseTTS      Boolean   @default(false) // User bought Vietnamese TTS addon
  vietnameseTTSExpiry   DateTime? // When the addon expires
  vietnameseTTSChars    Int       @default(0) // Chars used this month (soft limit tracking)

  // MASTERCLASS LIFETIME ADD-ON
  hasMasterclass        Boolean   @default(false) // Tracking lifetime course access decoupling from tool roles

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  membershipExpiry   DateTime?

  // AFFILIATE FIELDS (self-relation referrer / referredUsers)
  referrerId         String?
  referrer           User?     @relation("ReferralRelation", fields: [referrerId], references: [id])
  referredUsers      User[]    @relation("ReferralRelation")
  affiliateCode      String?   @unique
  isAffiliate        Boolean   @default(false)
  totalCommission    Decimal   @default(0)

  // Relations
  paymentRequests     PaymentRequest[]
  commissions         Commission[]    @relation("UserCommissions")
  referredCommissions Commission[]   @relation("CommissionReferredUser")
  payoutRequests      PayoutRequest[] @relation("UserPayouts")
  
  // Analytics
  attribution         UserAttribution?
  events              Event[]
  dubbingProjects     DubbingProject[]
  teacherRoadmap      TeacherRoadmap?
  chatMessages        ChatMessage[]
  
  // V2: Creator Hub Gamification
  badges              UserBadge[]

  streakDays          Int             @default(0)
  lastActiveAt        DateTime?

  // AI Voice Studio
  voices              UserVoice[]
  
  // Projects History
  projects            UserProject[]

  // YOUTUBE INTEGRATION (MULTI-CHANNEL SUPPORT)
  youtubeChannels     YouTubeChannel[]
  extraChannelSlots   Int             @default(0) // Extra slots purchased on top of plan limit

  // AI COACH PERSONALIZATION
  aiCoachSettings     Json?  // { nickname, channelInfo, personality, helpStyle, additionalInfo }

  // KODA DESKTOP LICENSE (Auto-gen from VPS 47.250.174.44)
  kodaLicenseKey      String?   // e.g. "KODA-VIP-A1B2C3D4"
  kodaTier            String?   // "vip", "studio", "novel", "combo_master"

  // PHASE 0: Creator Hub Foundation
  tier                String    @default("FREE") // FREE, BASIC, PRO, ENTERPRISE
  apiKeys             Json?    // { openai?: string, gemini?: string } - BYOK user-provided keys

  // Relations
  contentCalendar     ContentCalendar[]
  channelAnalytics   ChannelAnalytics[]
  marketplaceListings MarketplaceListing[] @relation("SellerListings")
  marketplaceTransactionsAsBuyer MarketplaceTransaction[] @relation("BuyerTransactions")
  marketplaceTransactionsAsSeller MarketplaceTransaction[] @relation("SellerTransactions")
  multiChannelConfigs MultiChannelConfig[]

  @@map("users")
}

model UserVoice {
  id        String   @id @default(cuid())
  userId    String
  voiceId   String   @unique
  name      String
  createdAt DateTime @default(now())
  expiresAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_voices")
}

model DubbingProject {
  id          String   @id @default(cuid())
  userId      String
  title       String?
  videoUrl    String   // Original Video URL
  status      String   @default("PROCESSING") // PROCESSING, COMPLETED, FAILED
  duration    Int?     // In seconds
  
  outputUrl   String?  // Final dubbed video URL
  transcript  Json?    // Array of segments { start, end, text, translatedText }
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@map("dubbing_projects")
}

model PaymentRequest {
  id           String    @id @default(cuid())
  orderCode    String    @unique
  userId       String?
  email        String
  role         String
  amount       Int
  txn          String?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  paidAt       DateTime?

  paymentInfo  String?

  approvedAt   DateTime?
  approvedBy   String?
  note         String?

  user         User?     @relation(fields: [userId], references: [id])

  @@map("payment_requests")
}

model Commission {
  id               String   @id @default(cuid())
  referrerId       String
  referredUserId   String
  paymentRequestId String?
  type             String
  amount           Decimal
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  approvedAt       DateTime?

  referrer         User     @relation("UserCommissions", fields: [referrerId], references: [id])
  referredUser     User     @relation("CommissionReferredUser", fields: [referredUserId], references: [id])

  @@map("commissions")
}

model PayoutRequest {
  id              String   @id @default(cuid())
  affiliateId     String
  amountRequested Decimal
  amountApproved  Decimal?
  bankInfo        Json
  status          String   @default("PENDING")
  requestedAt     DateTime @default(now())
  processedAt     DateTime?
  note            String?

  affiliate       User     @relation("UserPayouts", fields: [affiliateId], references: [id])

  @@map("payout_requests")
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  createdAt DateTime   @default(now())
  posts     BlogPost[]
  
  @@map("blog_categories")
}

model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  coverImage  String?
  summary     String?
  content     String        @db.Text
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  status      String        @default("DRAFT")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  publishedAt DateTime?
  
  @@map("blog_posts")
}

model Ebook {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  coverImageUrl   String?
  pdfUrl          String
  description     String?  @db.Text
  status          String   @default("DRAFT")
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ebooks")
}

model VideoTip {
  id           String   @id @default(cuid())
  title        String
  youtubeUrl   String
  youtubeId    String
  thumbnailUrl String?
  description  String?  @db.Text
  tags         String?
  type         String   @default("TUTORIAL") // TUTORIAL (Tool Guide), STRATEGY (Academy), TESTIMONIAL, BLOG
  status       String   @default("DRAFT")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("video_tips")
}

model Promotion {
  id             String    @id @default(cuid())
  code           String    @unique
  type           String    // PERCENT or FIXED
  value          Decimal
  promotionType  String    @default("CODE") // PROGRAM or CODE
  startDate      DateTime?
  endDate        DateTime?
  minOrder       Decimal?
  usageLimit     Int?      // Max usage count (null = unlimited)
  usageCount     Int       @default(0) // Current usage count
  status         String    @default("ACTIVE")
  description    String?
  imageUrl       String?   // Banner image URL
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  @@map("promotions")
}

model UserAttribution {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  anonId          String?

  // First Touch
  firstUtmSource   String?
  firstUtmMedium   String?
  firstUtmCampaign String?
  firstUtmTerm     String?
  firstUtmContent  String?
  firstGclid       String?
  firstReferrer    String?
  firstLandingPath String?
  firstSeenAt      DateTime?

  // Last Touch
  lastUtmSource    String?
  lastUtmMedium    String?
  lastUtmCampaign  String?
  lastUtmTerm      String?
  lastUtmContent   String?
  lastGclid        String?
  lastReferrer     String?
  lastLandingPath  String?
  lastSeenAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_attributions")
}

model Event {
  id          String   @id @default(cuid())
  name        String
  userId      String?
  anonId      String?
  path        String?
  properties  Json?
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([name, createdAt])
  @@index([userId])
  @@index([anonId])
  @@map("events")
}

model TeacherRoadmap {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  // Onboarding Data
  channelTopic    String?
  channelGoal     String?
  availableTime   String?
  contentMix      String?
  timezone        String?
  postingTime     String?
  content         Json?    // Stores the full 30-day AI generated plan

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  progress        TeacherRoadmapProgress[]

  @@map("teacher_roadmaps")
}

model TeacherRoadmapProgress {
  id              String   @id @default(cuid())
  roadmapId       String
  roadmap         TeacherRoadmap @relation(fields: [roadmapId], references: [id])

  day             Int      // 0 to 30
  status          String   @default("LOCKED") // LOCKED, OPEN, COMPLETED, SKIPPED

  unlockedAt      DateTime?
  completedAt     DateTime?

  @@unique([roadmapId, day])
  @@map("teacher_roadmap_progress")
}

// ============================================
// SEEN CHAT COMMUNITY MODELS
// ============================================

model ChatChannel {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g., 'general', 'newbie', 'flex'
  name        String
  icon        String?  // Emoji or Icon name
  description String?
  isLocked    Boolean  @default(false) // If true, requires special role/payment
  
  messages    ChatMessage[]
  
  // V2: Grouping & Type
  category    String   @default("GENERAL") // GENERAL, GROWTH, SPECIAL
  type        String   @default("CHAT")    // CHAT, SHOWCASE

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("chat_channels")
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  
  // V2: Flex Card Data
  type      String   @default("TEXT") // TEXT, FLEX, SYSTEM
  metadata  Json?    // { subCount, viewCount, topic, insight } for FLEX cards

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
  @@map("chat_messages")
}

// ============================================
// GAMIFICATION MODELS (V2)
// ============================================

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeCode String   // e.g., '1K_SUB', 'STREAK_7', 'HELPER'
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeCode])
  @@map("user_badges")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
model UserProject {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolId    String   // e.g., 'scriptwriter', 'veocity'
  name      String   // Project Name (e.g., Idea or Timestamp)
  data      Json     // The stored state (inputs, output)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, toolId])
  @@map("user_projects")
}

// Add relation to User model
// In User model:
// projects UserProject[]

// YOUTUBE INTEGRATION (MULTI-CHANNEL SUPPORT)
model YouTubeChannel {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  channelId       String   @unique
  title           String?
  thumbnail       String?
  subCount        Int      @default(0)
  viewCount       String?
  videoCount      Int      @default(0)
  
  accessToken     String?  @db.Text
  refreshToken    String?  @db.Text
  tokenExpiry     DateTime?
  lastSync        DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // CACHED DATA FOR DASHBOARD
  recentVideos    Json?    // Stores array of { id, title, thumbnail, views, publishedAt }
  channelHealth   Json?    // Stores health check summary { score, engagementRate, issues: [] }
  
  @@map("youtube_channels")
}

model ZoomRegistration {
  id        String   @id @default(cuid())
  name      String
  zalo      String
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("zoom_registrations")
}

// ============================================
// PHASE 0: CREATOR HUB FOUNDATION
// ============================================

// Content Calendar - schedule videos across platforms
model ContentCalendar {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  channelId       String?   // YouTubeChannel.id or tiktok_handle etc.
  platform        String    @default("youtube") // youtube, tiktok, facebook

  scheduledDate   DateTime
  title           String
  script          String?   @db.Text
  thumbnailUrl    String?
  videoUrl        String?   // Rendered video URL
  status          String    @default("DRAFT") // DRAFT, SCHEDULED, PUBLISHED, FAILED

  publishedAt     DateTime?
  youtubeVideoId  String?   // After publish, store the YouTube video ID

  seoTitle        String?
  seoDescription  String?   @db.Text
  seoTags         String[]  @default([])

  // AI metadata
  niche           String?
  targetAudience  String?

  // Notes
  notes           String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, scheduledDate])
  @@index([channelId, scheduledDate])
  @@index([userId, status])
  @@map("content_calendar")
}

// Channel Analytics Snapshots - historical performance tracking
model ChannelAnalytics {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  channelId       String    // YouTubeChannel.id

  // Snapshot date
  snapshotDate    DateTime  @default(now())

  // Core metrics
  subscribers     Int       @default(0)
  totalViews      BigInt    @default(0)
  videoCount      Int       @default(0)

  // Performance
  avgViewsPerVideo  Float   @default(0)
  avgEngagementRate Float   @default(0) // (likes + comments) / views * 100
  ctr              Float   @default(0)  // Click-through rate %
  retentionRate    Float   @default(0)  // Avg retention %

  // Revenue estimate
  estimatedRevenue Decimal  @default(0)

  // Traffic sources breakdown
  trafficSources   Json?    // { browse: 30, search: 40, external: 20, suggested: 10 }
  topCountries     Json?    // [{ country: "VN", views: 10000 }, ...]

  // Computed scores
  healthScore     Int       @default(50) // 0-100

  createdAt       DateTime  @default(now())

  @@unique([channelId, snapshotDate])
  @@index([channelId])
  @@index([userId, snapshotDate])
  @@map("channel_analytics")
}

// Channel Marketplace Listings
model MarketplaceListing {
  id              String    @id @default(cuid())
  userId          String

  // Channel info
  channelId       String    @unique // YouTubeChannel.id (if connected) or external
  channelUrl      String?   // For channels not yet connected
  channelTitle    String?
  channelThumbnail String?

  // Metrics at time of listing
  subscriberCount Int       @default(0)
  avgViewsPerVideo Float    @default(0)
  totalViews      BigInt    @default(0)
  videoCount      Int       @default(0)
  cpm             Float     @default(0) // Estimated CPM of the niche
  niche           String?

  // Pricing
  askingPrice     Decimal   @default(0)
  currency        String    @default("VND")

  // Verification status
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?   // Admin user ID

  // Listing details
  description     String?   @db.Text
  reasonForSelling String?
  includedContent String?   @db.Text // What's included: email, analytics access, etc.

  // Media evidence
  screenshots     String[]  @default([]) // URLs to screenshot images
  analyticsProof  Json?     // { avgViews: ..., subscriberCount: ... }

  // Status
  status          String    @default("PENDING") // PENDING, ACTIVE, SOLD, REMOVED, EXPIRED

  // Transaction
  buyerId         String?
  transactionId    String?
  salePrice       Decimal?
  soldAt          DateTime?
  completedAt     DateTime?

  // Admin review
  adminNote       String?   @db.Text
  reviewedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  expiresAt       DateTime? // Auto-expire after 30 days

  @@index([status])
  @@index([userId])
  @@index([niche])
  @@index([subscriberCount])
  @@map("marketplace_listings")
}

// Multi-Platform Configuration (TikTok, Facebook, etc.)
model MultiChannelConfig {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform        String    // tiktok, facebook, instagram, twitter
  platformUserId  String    // Platform's user ID / page ID
  platformHandle  String?   // @handle or page name

  // OAuth tokens
  accessToken     String?   @db.Text
  refreshToken    String?   @db.Text
  tokenExpiry     DateTime?

  // Channel metadata
  displayName    String?
  profileImage    String?
  followerCount   Int       @default(0)
  pageUrl        String?

  // Auto-publish settings
  autoPublish     Boolean   @default(false)
  defaultSchedule String?   // "09:00" UTC time for posting

  // Sync status
  lastSync        DateTime?
  syncError       String?

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, platform, platformUserId])
  @@index([userId, platform])
  @@map("multi_channel_configs")
}

// Marketplace Transactions (Escrow tracking)
model MarketplaceTransaction {
  id              String    @id @default(cuid())

  listingId       String
  listing         MarketplaceListing @relation(fields: [listingId], references: [id])

  sellerId        String
  buyerId         String

  // Pricing
  agreedPrice     Decimal
  platformFee     Decimal   @default(0)
  netAmount       Decimal   @default(0)

  // Payment
  paymentStatus   String    @default("PENDING") // PENDING, PAID, RELEASED, REFUNDED
  paymentId       String?   // PayOS / Stripe payment ID
  paidAt          DateTime?

  // Channel transfer
  transferStatus  String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, DISPUTED
  transferNotes   String?   @db.Text
  completedAt     DateTime?

  // Dispute
  disputeReason   String?   @db.Text
  disputeOpenedAt DateTime?
  disputeResolvedAt DateTime?
  disputeWinner   String?   // 'buyer' or 'seller'

  // Verification
  channelVerified Boolean   @default(false)
  channelTransferred Boolean @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@map("marketplace_transactions")
}

// User tier & API Keys extension
// (These fields are added to User model via migration)
// tier: FREE | BASIC | PRO | ENTERPRISE
// apiKeys: JSON { openai: "...", gemini: "..." } - user-provided API keys for BYOK

