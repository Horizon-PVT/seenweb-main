generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  image              String?
  passwordHash       String?
  role               String    @default("FREE")

  // QUOTA FIELDS
  dailyUsage         Int       @default(0)
  maxDailyUsage      Int       @default(3) // Updated from 2 to 3

  // ✅ NEW: dùng để reset dailyUsage theo ngày (không cần cron)
  lastUsageDate      DateTime? // New field for daily reset logic

  // TTS QUOTA TRACKING
  ttsUsageChars      Int       @default(0)
  ttsLastReset       String?

  // AI DUBBING CREDITS
  dubbingCredits     Int       @default(0) // 1 credit = 1 video minute (or similar)

  // VIETNAMESE TTS ADD-ON (59k upsell)
  hasVietnameseTTS      Boolean   @default(false) // User bought Vietnamese TTS addon
  vietnameseTTSExpiry   DateTime? // When the addon expires
  vietnameseTTSChars    Int       @default(0) // Chars used this month (soft limit tracking)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  membershipExpiry   DateTime?

  // AFFILIATE FIELDS (self-relation referrer / referredUsers)
  referrerId         String?
  referrer           User?     @relation("ReferralRelation", fields: [referrerId], references: [id])
  referredUsers      User[]    @relation("ReferralRelation")
  affiliateCode      String?   @unique
  isAffiliate        Boolean   @default(false)
  totalCommission    Decimal   @default(0)

  // Relations
  paymentRequests     PaymentRequest[]
  commissions         Commission[]    @relation("UserCommissions")
  referredCommissions Commission[]   @relation("CommissionReferredUser")
  payoutRequests      PayoutRequest[] @relation("UserPayouts")
  
  // Analytics
  attribution         UserAttribution?
  events              Event[]
  dubbingProjects     DubbingProject[]
  teacherRoadmap      TeacherRoadmap?
  chatMessages        ChatMessage[]
  
  // V2: Creator Hub Gamification
  badges              UserBadge[]
  youtubeSubCount     Int             @default(0)
  streakDays          Int             @default(0)
  lastActiveAt        DateTime?

  // AI Voice Studio
  voices              UserVoice[]

  @@map("users")
}

model UserVoice {
  id        String   @id @default(cuid())
  userId    String
  voiceId   String   @unique
  name      String
  createdAt DateTime @default(now())
  expiresAt DateTime?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_voices")
}

model DubbingProject {
  id          String   @id @default(cuid())
  userId      String
  title       String?
  videoUrl    String   // Original Video URL
  status      String   @default("PROCESSING") // PROCESSING, COMPLETED, FAILED
  duration    Int?     // In seconds
  
  outputUrl   String?  // Final dubbed video URL
  transcript  Json?    // Array of segments { start, end, text, translatedText }
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@map("dubbing_projects")
}

model PaymentRequest {
  id           String    @id @default(cuid())
  orderCode    String    @unique
  userId       String?
  email        String
  role         String
  amount       Int
  txn          String?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  paidAt       DateTime?

  paymentInfo  String?

  approvedAt   DateTime?
  approvedBy   String?
  note         String?

  user         User?     @relation(fields: [userId], references: [id])

  @@map("payment_requests")
}

model Commission {
  id               String   @id @default(cuid())
  referrerId       String
  referredUserId   String
  paymentRequestId String?
  type             String
  amount           Decimal
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  approvedAt       DateTime?

  referrer         User     @relation("UserCommissions", fields: [referrerId], references: [id])
  referredUser     User     @relation("CommissionReferredUser", fields: [referredUserId], references: [id])

  @@map("commissions")
}

model PayoutRequest {
  id              String   @id @default(cuid())
  affiliateId     String
  amountRequested Decimal
  amountApproved  Decimal?
  bankInfo        Json
  status          String   @default("PENDING")
  requestedAt     DateTime @default(now())
  processedAt     DateTime?
  note            String?

  affiliate       User     @relation("UserPayouts", fields: [affiliateId], references: [id])

  @@map("payout_requests")
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  createdAt DateTime   @default(now())
  posts     BlogPost[]
  
  @@map("blog_categories")
}

model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  coverImage  String?
  summary     String?
  content     String        @db.Text
  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])
  status      String        @default("DRAFT")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  publishedAt DateTime?
  
  @@map("blog_posts")
}

model Ebook {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  coverImageUrl   String?
  pdfUrl          String
  description     String?  @db.Text
  status          String   @default("DRAFT")
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("ebooks")
}

model VideoTip {
  id           String   @id @default(cuid())
  title        String
  youtubeUrl   String
  youtubeId    String
  thumbnailUrl String?
  description  String?  @db.Text
  tags         String?
  status       String   @default("DRAFT")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("video_tips")
}

model Promotion {
  id             String    @id @default(cuid())
  code           String    @unique
  type           String    // PERCENT or FIXED
  value          Decimal
  promotionType  String    @default("CODE") // PROGRAM or CODE
  startDate      DateTime?
  endDate        DateTime?
  minOrder       Decimal?
  usageLimit     Int?      // Max usage count (null = unlimited)
  usageCount     Int       @default(0) // Current usage count
  status         String    @default("ACTIVE")
  description    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  @@map("promotions")
}

model UserAttribution {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  anonId          String?

  // First Touch
  firstUtmSource   String?
  firstUtmMedium   String?
  firstUtmCampaign String?
  firstUtmTerm     String?
  firstUtmContent  String?
  firstGclid       String?
  firstReferrer    String?
  firstLandingPath String?
  firstSeenAt      DateTime?

  // Last Touch
  lastUtmSource    String?
  lastUtmMedium    String?
  lastUtmCampaign  String?
  lastUtmTerm      String?
  lastUtmContent   String?
  lastGclid        String?
  lastReferrer     String?
  lastLandingPath  String?
  lastSeenAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_attributions")
}

model Event {
  id          String   @id @default(cuid())
  name        String
  userId      String?
  anonId      String?
  path        String?
  properties  Json?
  ipHash      String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@index([name, createdAt])
  @@index([userId])
  @@index([anonId])
  @@map("events")
}

model TeacherRoadmap {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  // Onboarding Data
  channelTopic    String?
  channelGoal     String?
  availableTime   String?
  contentMix      String?
  timezone        String?
  postingTime     String?
  content         Json?    // Stores the full 30-day AI generated plan

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  progress        TeacherRoadmapProgress[]

  @@map("teacher_roadmaps")
}

model TeacherRoadmapProgress {
  id              String   @id @default(cuid())
  roadmapId       String
  roadmap         TeacherRoadmap @relation(fields: [roadmapId], references: [id])

  day             Int      // 0 to 30
  status          String   @default("LOCKED") // LOCKED, OPEN, COMPLETED, SKIPPED

  unlockedAt      DateTime?
  completedAt     DateTime?

  @@unique([roadmapId, day])
  @@map("teacher_roadmap_progress")
}

// ============================================
// SEEN CHAT COMMUNITY MODELS
// ============================================

model ChatChannel {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g., 'general', 'newbie', 'flex'
  name        String
  icon        String?  // Emoji or Icon name
  description String?
  isLocked    Boolean  @default(false) // If true, requires special role/payment
  
  messages    ChatMessage[]
  
  // V2: Grouping & Type
  category    String   @default("GENERAL") // GENERAL, GROWTH, SPECIAL
  type        String   @default("CHAT")    // CHAT, SHOWCASE

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("chat_channels")
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  
  // V2: Flex Card Data
  type      String   @default("TEXT") // TEXT, FLEX, SYSTEM
  metadata  Json?    // { subCount, viewCount, topic, insight } for FLEX cards

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  channelId String
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([channelId, createdAt])
  @@map("chat_messages")
}

// ============================================
// GAMIFICATION MODELS (V2)
// ============================================

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeCode String   // e.g., '1K_SUB', 'STREAK_7', 'HELPER'
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeCode])
  @@map("user_badges")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
